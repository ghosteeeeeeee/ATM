# Hyperliquid credentials — copy this to .secrets.local and fill in your values.
# .secrets.local is gitignored and MUST NOT be committed.
SIGNING_KEY="YOUR_SIGNING_WALLET_PRIVATE_KEY_HERE"
# Addresses are safe to commit (not secrets)
SIGNING_WALLET_ADDRESS="0xYourSigningWalletAddress"
MAIN_ACCOUNT_ADDRESS="0xYourMainTradingAccountAddress"
