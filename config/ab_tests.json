          }
        },
        {
          "id": "RETRACE-5",
          "label": "Retrace 5% pullback",
          "weight": 1,
          "enabled": true,
          "config": {
            "entryMode": "retrace",
            "pullbackThreshold": 5.0
          }
        }
      ]
    },
    {
      "name": "trailing-stop-test",
      "description": "Trailing stop parameters — activation threshold and distance",
