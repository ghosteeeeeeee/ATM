            "trailingDistancePct": 0.5
          }
        },
        {
          "id": "TS-normal",
          "label": "Normal trailing: 1% activation / 1% distance",
          "weight": 1,
          "enabled": true,
          "config": {
            "trailingActivationPct": 1.0,
            "trailingDistancePct": 1.0
          }
        },
        {
          "id": "TS-loose",
          "label": "Loose trailing: 2% activation / 1% distance",
          "weight": 1,
          "enabled": true,
          "config": {
            "trailingActivationPct": 2.0,
            "trailingDistancePct": 1.0
          }
        }
      ]
    },
    {
