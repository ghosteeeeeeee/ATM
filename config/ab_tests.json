          }
        },
        {
          "id": "SL2pct",
          "label": "2% SL (control)",
          "weight": 1,
          "enabled": true,
          "config": {
            "slPct": 2.0
          }
        },
        {
          "id": "SL3pct",
          "label": "3% SL (loose)",
          "weight": 1,
          "enabled": true,
          "config": {
            "slPct": 3.0
          }
        }
      ]
    },
    {
      "name": "entry-timing-test",
