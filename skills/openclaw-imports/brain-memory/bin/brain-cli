#!/bin/bash
# Brain API CLI - Call Brain from anywhere via SSH tunnel

BRAIN_HOST="117.55.192.97"
SSH_PORT="333"

case "$1" in
  stats)
    ssh -o StrictHostKeyChecking=no -p $SSH_PORT root@$BRAIN_HOST "curl -s http://127.0.0.1:5433/api/stats"
    ;;
  search)
    ssh -o StrictHostKeyChecking=no -p $SSH_PORT root@$BRAIN_HOST "curl -s 'http://127.0.0.1:5433/api/search?q=$2'"
    ;;
  semantic)
    ssh -o StrictHostKeyChecking=no -p $SSH_PORT root@$BRAIN_HOST "curl -s 'http://127.0.0.1:5433/api/semantic?q=$2'"
    ;;
  add)
    CONTENT="$2"
    SOURCE="${3:-cli}"
    ssh -o StrictHostKeyChecking=no -p $SSH_PORT root@$BRAIN_HOST "curl -s -X POST http://127.0.0.1:5433/api/add -H 'Content-Type: application/json' -d '{\"content\": \"$CONTENT\", \"source\": \"$SOURCE\"}'"
    ;;
  related)
    ssh -o StrictHostKeyChecking=no -p $SSH_PORT root@$BRAIN_HOST "curl -s http://127.0.0.1:5433/api/related/$2"
    ;;
  tags)
    ssh -o StrictHostKeyChecking=no -p $SSH_PORT root@$BRAIN_HOST "curl -s http://127.0.0.1:5433/api/bytag/$2"
    ;;
  *)
    echo "Usage: $0 {stats|search <q>|semantic <q>|add <content> [source]|related <id>|tags <tag>}"
    exit 1
    ;;
esac
